{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manifest.schema.json",
  "title": "Plugins AI Manifest",
  "description": "Schema for validating the plugins-ai manifest.json structure",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "description",
    "updated_at",
    "stats",
    "agents",
    "skills",
    "commands",
    "shared"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the manifest schema"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the plugin collection"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Description of the plugin collection"
    },
    "updated_at": {
      "type": "string",
      "format": "date",
      "description": "Date the manifest was last updated (ISO 8601 date string)"
    },
    "stats": {
      "$ref": "#/$defs/Stats"
    },
    "agents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Agent"
      },
      "description": "List of agent definitions"
    },
    "skills": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Skill"
      },
      "description": "List of skill definitions"
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Command"
      },
      "description": "List of command definitions"
    },
    "shared": {
      "$ref": "#/$defs/Shared"
    }
  },
  "$defs": {
    "Stats": {
      "type": "object",
      "required": [
        "total_skills",
        "total_agents",
        "total_commands",
        "total_protocols",
        "total_templates",
        "total_style_guides"
      ],
      "additionalProperties": false,
      "properties": {
        "total_skills": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of skills"
        },
        "total_agents": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of agents"
        },
        "total_commands": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of commands"
        },
        "total_protocols": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of protocols"
        },
        "total_templates": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of templates"
        },
        "total_style_guides": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of style guides"
        }
      }
    },
    "Agent": {
      "type": "object",
      "required": [
        "name",
        "description",
        "model",
        "tools",
        "dispatch_triggers",
        "capabilities",
        "path"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Agent name"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Agent description"
        },
        "model": {
          "type": "string",
          "enum": ["sonnet", "opus", "haiku"],
          "description": "Claude model variant used by this agent"
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "List of tools available to this agent"
        },
        "dispatch_triggers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Trigger phrases or patterns that activate this agent"
        },
        "capabilities": {
          "type": "object",
          "description": "Key-value map of agent capabilities"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Filesystem path to the agent definition"
        }
      }
    },
    "Skill": {
      "type": "object",
      "required": [
        "name",
        "description",
        "dispatch_triggers",
        "has_scripts",
        "has_references",
        "path"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Skill name"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Skill description"
        },
        "dispatch_triggers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Trigger phrases or patterns that activate this skill"
        },
        "has_scripts": {
          "type": "boolean",
          "description": "Whether this skill includes executable scripts"
        },
        "has_references": {
          "type": "boolean",
          "description": "Whether this skill includes reference documents"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Filesystem path to the skill definition"
        }
      }
    },
    "Command": {
      "type": "object",
      "required": ["name", "description", "path"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Command name"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Command description"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Filesystem path to the command definition"
        }
      }
    },
    "Shared": {
      "type": "object",
      "required": [
        "protocols",
        "templates",
        "style_guides",
        "tokens",
        "references",
        "python_library"
      ],
      "additionalProperties": false,
      "properties": {
        "protocols": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NamedResource"
          },
          "description": "Shared protocol definitions"
        },
        "templates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NamedResource"
          },
          "description": "Shared template definitions"
        },
        "style_guides": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NamedResource"
          },
          "description": "Shared style guide definitions"
        },
        "tokens": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NamedResource"
          },
          "description": "Shared token definitions"
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          },
          "description": "Shared reference documents"
        },
        "python_library": {
          "$ref": "#/$defs/PythonLibrary"
        }
      }
    },
    "NamedResource": {
      "type": "object",
      "required": ["name", "description", "path"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Resource name"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Resource description"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Filesystem path to the resource"
        }
      }
    },
    "Reference": {
      "type": "object",
      "required": ["name", "path"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Reference name"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Filesystem path to the reference"
        }
      }
    },
    "PythonLibrary": {
      "type": "object",
      "required": ["base_path", "layers", "test_directory"],
      "additionalProperties": false,
      "properties": {
        "base_path": {
          "type": "string",
          "minLength": 1,
          "description": "Base filesystem path of the Python library"
        },
        "layers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Ordered list of library layers"
        },
        "test_directory": {
          "type": "string",
          "minLength": 1,
          "description": "Path to the test directory for the Python library"
        }
      }
    }
  }
}
